generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 体験記
model Experience {
  id                  String   @id @default(uuid())
  university          String
  faculty             String
  year                Int
  authorPseudonym     String
  jukuCampus          String   @default("自力合格")  // Loohcs志塾の校舎名

  // 投稿者情報
  submitterName       String
  submitterEmail      String
  submitterPhone      String?

  selectionProcess    String
  interviewQuestions  String
  interviewAtmosphere String

  preparationTips     String
  adviceToJuniors     String

  motivationTheme     String?
  motivationStructure String?

  // レビュー・承認フロー
  status              String   @default("PENDING_REVIEW") // DRAFT, PENDING_REVIEW, REVISION_REQUESTED, APPROVED, PUBLISHED
  reviewComments      String?
  reviewedBy          String?
  reviewedAt          DateTime?

  // 報酬管理
  paymentStatus       String   @default("PENDING") // PENDING, COMPLETED
  paymentAmount       Int?
  paymentDate         DateTime?

  viewCount           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("experiences")
}

// 無料相談予約
model Consultation {
  id              String   @id @default(uuid())
  trackingId      String   @unique @default(uuid())
  
  name            String
  email           String
  phone           String
  grade           String
  university      String
  faculty         String
  concerns        String
  
  consultationType String
  preferredDate    String
  preferredTime    String

  jukuCampus       String   // Loohcs志塾の校舎名
  status           String   @default("PENDING")
  
  createdAt        DateTime @default(now())
  
  @@map("consultations")
}

// Loohcs志塾スタッフ
model Staff {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String
  jukuCampus String   // 所属校舎
  role       String   @default("STAFF")

  createdAt  DateTime @default(now())

  @@map("staff")
}

// Loohcs志塾の書類
model Document {
  id           String   @id @default(uuid())
  jukuCampus   String   // 校舎名

  university   String
  faculty      String
  year         Int
  documentType String
  title        String

  fullText     String

  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("documents")
}